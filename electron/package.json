{
  "name": "whithin",
  "productName": "Whithin",
  "version": "1.0.6",
  "description": "Whithin desktop shell",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "main.cjs",
  "scripts": {
    "start": "electron ./main.cjs",
    "dev": "cross-env WEB_CLIENT_URL=http://localhost:5173 electron ./main.cjs",
    "start:web": "cross-env WEB_CLIENT_URL=https://whithin.ru electron ./main.cjs",
    "build:audio-bridge": "dotnet publish Whithin.AudioBridge/Whithin.AudioBridge.csproj -c Release -r win-x64 -o audio-bridge-bin --no-self-contained",
    "dist": "npm run build:audio-bridge && electron-builder",
    "dist:win": "npm run build:audio-bridge && electron-builder --win nsis"
  },
  "config": {
    "forge": "./forge.config.cjs"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1",
    "rcedit": "^4.0.1"
  },
  "build": {
    "appId": "ru.whithin.desktop",
    "productName": "Whithin",
    "executableName": "Whithin",
    "asar": true,
    "asarUnpack": [
      "node_modules/global-mouse-events/**/*.node",
      "node_modules/node-global-key-listener/**/*.exe"
    ],
    "directories": {
      "output": "release"
    },
    "afterPack": "./scripts/after-pack.cjs",
    "files": [
      "main.cjs",
      "preload.cjs",
      "audioBridge.cjs",
      "picker-preload.cjs",
      "screen-picker.html",
      "tray.png",
      "app-icon.png",
      "app-icon.ico",
      "package.json",
      "audio-bridge-bin/**/*",
      "node_modules/global-mouse-events/**/*",
      "node_modules/node-global-key-listener/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "extraResources": [
      {
        "from": "audio-bridge-bin",
        "to": "audio-bridge-bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "app-icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "app-icon.ico",
      "uninstallerIcon": "app-icon.ico",
      "installerHeaderIcon": "app-icon.ico"
    }
  },
  "dependencies": {
    "global-mouse-events": "^1.2.0",
    "node-global-key-listener": "^0.3.0"
  }
}
